<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sovereign Vault Login | Yadhee Administrative Access</title>
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
    <!-- Icon library -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --color-ivory: #FDFBF7;
            --color-gold: #C5A059;
            --color-gold-bright: #D4AF37;
            --color-crimson-deep: #5E0611;
            --color-dark-ruby: #1E0206;
            --color-charcoal: #2A2425;
            --font-heading: 'Cinzel', serif;
            --font-body: 'Montserrat', sans-serif;
            --transition-smooth: all 0.5s cubic-bezier(0.25, 1, 0.5, 1);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background-color: var(--color-dark-ruby);
            color: var(--color-ivory);
            font-family: var(--font-body);
            font-weight: 300;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            background-image: linear-gradient(rgba(30, 2, 6, 0.95), rgba(30, 2, 6, 0.9)), url('/assets/hero_saree.png');
            background-size: cover;
            background-position: center;
        }

        .login-card {
            width: 100%;
            max-width: 450px;
            background: rgba(42, 36, 37, 0.75);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(197, 160, 89, 0.25);
            padding: 3.5rem 3rem;
            box-shadow: 0 30px 70px rgba(0, 0, 0, 0.5);
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
        }

        .brand-title {
            font-family: var(--font-heading);
            font-size: 2rem;
            font-weight: 600;
            letter-spacing: 0.3em;
            color: var(--color-gold-bright);
            line-height: 1.2;
            margin-bottom: 0.3rem;
        }

        .brand-subtitle {
            font-size: 0.6rem;
            font-weight: 500;
            letter-spacing: 0.4em;
            color: var(--color-ivory);
            text-transform: uppercase;
            margin-bottom: 2.5rem;
            opacity: 0.8;
        }

        .form-title {
            font-family: var(--font-heading);
            font-size: 1.1rem;
            font-weight: 400;
            letter-spacing: 0.15em;
            color: var(--color-ivory);
            margin-bottom: 1.8rem;
            text-transform: uppercase;
            border-bottom: 1px solid rgba(197, 160, 89, 0.2);
            padding-bottom: 0.8rem;
            width: 100%;
        }

        .luxury-form {
            width: 100%;
        }

        .form-group {
            margin-bottom: 1.8rem;
            text-align: left;
            position: relative;
        }

        label {
            font-family: var(--font-heading);
            font-size: 0.75rem;
            letter-spacing: 0.15em;
            color: var(--color-gold);
            text-transform: uppercase;
            display: block;
            margin-bottom: 0.6rem;
            font-weight: 600;
        }

        input {
            width: 100%;
            background: rgba(30, 2, 6, 0.4);
            border: 1px solid rgba(197, 160, 89, 0.25);
            padding: 1rem 1.2rem;
            font-family: var(--font-body);
            color: var(--color-ivory);
            font-size: 0.9rem;
            transition: var(--transition-smooth);
        }

        input:focus {
            outline: none;
            border-color: var(--color-gold-bright);
            background: rgba(30, 2, 6, 0.7);
            box-shadow: 0 0 10px rgba(212, 175, 55, 0.1);
        }

        .submit-btn {
            width: 100%;
            background-color: var(--color-crimson-deep);
            color: var(--color-ivory);
            border: 1px solid var(--color-gold);
            padding: 1.1rem;
            font-family: var(--font-heading);
            font-size: 0.8rem;
            font-weight: 600;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            cursor: pointer;
            transition: var(--transition-smooth);
            margin-top: 1rem;
        }

        .submit-btn:hover {
            background-color: var(--color-gold-bright);
            color: var(--color-dark-ruby);
            box-shadow: 0 10px 30px rgba(212, 175, 55, 0.25);
        }

        .error-message {
            background: rgba(122, 12, 30, 0.2);
            border: 1px solid var(--color-gold);
            color: var(--color-ivory);
            font-size: 0.8rem;
            padding: 0.8rem 1rem;
            margin-bottom: 1.8rem;
            width: 100%;
            letter-spacing: 0.05em;
            text-align: center;
        }

        .back-home {
            margin-top: 2rem;
            font-size: 0.75rem;
            letter-spacing: 0.1em;
            color: var(--color-gold);
            text-decoration: none;
            transition: var(--transition-smooth);
        }

        .back-home:hover {
            color: var(--color-ivory);
        }
    </style>
</head>
<body>

    <div class="login-card">
        <img src="/assets/logo.jpg" alt="Yadhee Logo" class="brand-logo-img" style="height: 52px; width: auto; object-fit: contain; margin-bottom: 0.3rem;">
        <div class="brand-subtitle">HERITAGE OF WEAVES & JEWELS</div>

        <h3 class="form-title">Sovereign Vault Login</h3>

        <% if (error) { %>
            <div class="error-message">
                <i class="fa-solid fa-triangle-exclamation"></i> <%= error %>
            </div>
        <% } %>

        <form action="/admin/login" method="POST" class="luxury-form">
            <div class="form-group">
                <label for="username">Administrator</label>
                <input type="text" id="username" name="username" required autocomplete="off" placeholder="Enter key username...">
            </div>
            
            <div class="form-group">
                <label for="password">Security Cipher</label>
                <input type="password" id="password" name="password" required placeholder="•••••••••••••••">
            </div>

            <button type="submit" class="submit-btn">Authorise Portal <i class="fa-solid fa-key"></i></button>
        </form>

        <a href="/" class="back-home"><i class="fa-solid fa-arrow-left-long"></i> Return to Front Salons</a>
    </div>

</body>
</html>
