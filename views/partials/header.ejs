<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="<%= typeof description !== 'undefined' ? description : 'Yadhee - High-end cinematic e-commerce experience featuring luxurious handwoven royal silk sarees and exquisite antique heritage gold jewelry.' %>">
    <title><%= typeof title !== 'undefined' ? title : 'Yadhee | Royal Handwoven Sarees & Heritage Jewels' %></title>
    <!-- Fonts: Cormorant Garamond for elegant serifs, Cinzel for brand titles, Montserrat for sleek typography, and Figtree/Merriweather from Madhurika Attires -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,400&family=Montserrat:wght@300;400;500;600&family=Figtree:wght@300;400;500;600;700&family=Merriweather:ital,wght@0,300;0,400;0,700;1,300&family=Pinyon+Script&display=swap" rel="stylesheet">
    <!-- FontAwesome for minimal elegant icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="style.css">
</head>
<body data-logged-in="<%= user ? 'true' : 'false' %>">

    <!-- Left-Side Sliding Navigation Drawer -->
    <div class="sidebar-drawer-overlay" id="sidebarDrawerOverlay"></div>
    <div class="sidebar-drawer" id="sidebarDrawer" role="dialog" aria-modal="true" aria-label="Explore Menu">
        <!-- Drawer Header -->
        <div class="drawer-header">
            <h3>Explore</h3>
            <button class="drawer-close-btn" id="drawerClose" aria-label="Close Menu">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
        
        <!-- Drawer Menu Body -->
        <div class="drawer-menu-body">
            <a href="/" class="drawer-menu-link">Home</a>
            <a href="/bestsellers" class="drawer-menu-link">Best Sellers</a>
            <a href="/new-arrivals" class="drawer-menu-link">New Arrivals</a>
            
            <!-- Expandable Collections Group -->
            <div class="drawer-menu-group">
                <div class="group-header" id="collectionsGroupHeader">
                    <span>Collections</span>
                    <i class="fa-solid fa-plus group-caret"></i>
                </div>
                <div class="group-links" id="collectionsGroupLinks">
                    <a href="/sarees" class="group-sublink">Sarees</a>
                    <a href="/jewels" class="group-sublink">Jewels</a>
                </div>
            </div>

            <!-- Expandable Brands Group -->
            <div class="drawer-menu-group">
                <div class="group-header" id="brandsGroupHeader">
                    <span>Brands</span>
                    <i class="fa-solid fa-plus group-caret"></i>
                </div>
                <div class="group-links" id="brandsGroupLinks">
                    <a href="/about" class="group-sublink">Our Story</a>
                    <a href="/contact" class="group-sublink">Contact Us</a>
                </div>
            </div>
        </div>
        
        <!-- Drawer Footer (Solid Black Login Bar) -->
        <div class="drawer-footer">
            <% if (typeof user !== 'undefined' && user) { %>
                <div class="drawer-user-info">
                    <span class="user-name-label">Logged in as: <strong><%= user.username %></strong></span>
                    <div class="footer-links-row">
                        <a href="/vault" class="footer-action-link">My Account</a>
                        <a href="/logout" class="footer-action-link logout-btn-text">Logout</a>
                    </div>
                </div>
            <% } else { %>
                <a href="/login" class="drawer-login-btn">Log in</a>
            <% } %>
        </div>
    </div>

    <!-- Custom Luxury Cursor Ring -->
    <div id="custom-cursor" class="custom-cursor"></div>
    <div id="custom-cursor-dot" class="custom-cursor-dot"></div>

    <!-- Top Luxury Announcement Bar -->
    <div class="announcement-bar" id="announcementBar">
        <div class="announcement-slider">
            <span class="announcement-item">FREE SHIPPING IN INDIA</span>
            <span class="announcement-item">Delivery Time: 15-20 Working Days</span>
            <span class="announcement-item">FREE SHIPPING IN INDIA</span>
            <span class="announcement-item">Delivery Time: 15-20 Working Days</span>
            <span class="announcement-item">FREE SHIPPING IN INDIA</span>
            <span class="announcement-item">Delivery Time: 15-20 Working Days</span>
        </div>
        <button class="announcement-close-btn" id="closeAnnouncement" aria-label="Close Announcement">✕</button>
    </div>

    <!-- Elegant Sticky Navigation Header -->
    <header class="main-header">
        <div class="nav-container">
            <!-- Left Navigation Menu Links -->
            <nav class="nav-links" style="align-items: center;">
                <button class="nav-hamburger-btn" id="menuHamburger" aria-label="Open Menu">
                    <i class="fa-solid fa-bars"></i>
                </button>
                <a href="/" class="nav-item <%= activePage === 'home' ? 'active' : '' %>">Home</a>
                <a href="/bestsellers" class="nav-item <%= activePage === 'bestsellers' ? 'active' : '' %>">Best Sellers</a>
                <a href="/new-arrivals" class="nav-item <%= activePage === 'new-arrivals' ? 'active' : '' %>">New Arrivals</a>
            </nav>

            <!-- Brand Logo in Center -->
            <div class="brand-logo-container">
                <a href="/" class="brand-logo">
                    <span class="brand-title">Yadhee</span>
                    <span class="brand-subtitle">HERITAGE OF WEAVES & JEWELS</span>
                </a>
            </div>

            <!-- Right Actions Bar -->
            <div class="nav-actions">
                <button class="action-btn search-toggle" id="searchToggle" aria-label="Search Collection">
                    <i class="fa-solid fa-magnifying-glass"></i>
                </button>
                <button class="action-btn favorites-btn" id="favsToggle" aria-label="Wishlist">
                    <i class="fa-regular fa-heart"></i>
                    <span class="action-badge favs-count">0</span>
                </button>
                <button class="action-btn bag-btn" id="cartToggle" aria-label="Shopping Bag">
                    <i class="fa-solid fa-bag-shopping"></i>
                    <span class="action-badge cart-count">0</span>
                </button>
                <% if (typeof user !== 'undefined' && user) { %>
                    <div class="user-menu-container">
                        <button class="action-btn user-btn" id="userMenuToggle" aria-label="My Account">
                            <i class="fa-regular fa-user"></i>
                        </button>
                        <div class="user-dropdown" id="userDropdown">
                            <div class="dropdown-header">
                                <span class="patron-title">My Account</span>
                                <span class="patron-name"><%= user.username %></span>
                            </div>
                            <hr class="dropdown-divider">
                            <a href="/vault" class="dropdown-item"><i class="fa-solid fa-gem"></i> My Orders</a>
                            <a href="/logout" class="dropdown-item"><i class="fa-solid fa-arrow-right-from-bracket"></i> Logout</a>
                        </div>
                    </div>
                <% } else { %>
                    <a href="/login" class="action-btn login-link" aria-label="Login">
                        <i class="fa-regular fa-user"></i>
                    </a>
                <% } %>
            </div>
        </div>
    </header>

    <!-- Interactive Sliding Search Bar (Appears on clicking search icon) -->
    <div class="search-overlay" id="searchOverlay">
        <div class="search-box">
            <input type="text" id="searchInput" placeholder="Search Yadhee..." autocomplete="off">
            <button class="search-submit-btn"><i class="fa-solid fa-arrow-right-long"></i></button>
            <button class="search-close" id="searchClose"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div class="search-suggestions">
            <span>Popular:</span>
            <a href="/sarees" class="suggested-link">Kanchipuram Silk</a>
            <a href="/jewels" class="suggested-link">Temple Chokers</a>
            <a href="/jewels" class="suggested-link">Polki Jhumkas</a>
        </div>
    </div>
