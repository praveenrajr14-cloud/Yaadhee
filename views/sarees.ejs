<%- include('partials/header', { activePage: 'sarees', title: 'The Sarees Collection | Yadhee Luxury Heritage' }) %>

    <!-- Page Banner Header -->
    <section class="page-title-banner" style="background-image: linear-gradient(rgba(30, 2, 6, 0.85), rgba(30, 2, 6, 0.7)), url('assets/hero_saree.png');">
        <div class="banner-content text-center">
            <span class="section-accent">Generational Loom Collections</span>
            <h1 class="page-main-title">The Royal Handwoven Sarees</h1>
            <p class="banner-subtitle">Explore pure silk fabrics meticulously handwoven with precious metallic gold threads by legendary master artisans.</p>
        </div>
    </section>

    <!-- Filterable Product Grid -->
    <section class="gallery-section">
        <div class="section-container">
            <div class="gallery-header text-center reveal-on-scroll">
                <span class="section-accent">The Weaves Vault</span>
                <h2 class="section-title">Acquire Heirloom Silks</h2>
                
                <!-- Specialized Sub-category Filter Buttons -->
                <div class="filter-controls">
                    <button class="filter-btn active" data-filter="all">All Loom Weaves</button>
                    <button class="filter-btn" data-filter="kanchipuram">Kanchipuram Silks</button>
                    <button class="filter-btn" data-filter="banarasi">Banarasi Satins</button>
                    <button class="filter-btn" data-filter="organza">Regal Organzas</button>
                </div>
            </div>

            <!-- Custom Saree Grid -->
            <div class="product-grid" id="productGrid">
                <% products.forEach(function(product) { %>
                <div class="product-card reveal-on-scroll" data-category="<%= product.subcategory %>" data-id="<%= product.id %>">
                    <div class="product-media-wrapper">
                        <img src="<%= product.image_url %>" alt="<%= product.name %>" class="product-img">
                        <div class="card-overlay-actions">
                            <button class="card-btn quick-view-btn" aria-label="Quick View"><i class="fa-solid fa-eye"></i></button>
                            <button class="card-btn fav-add-btn" aria-label="Add to Wishlist"><i class="fa-regular fa-heart"></i></button>
                        </div>
                        <% if (product.stock_quantity === 1) { %>
                            <span class="product-tag scarcity-tag alert-tag">Only 1 Left</span>
                        <% } else if (product.stock_quantity === 2) { %>
                            <span class="product-tag scarcity-tag warning-tag">Rare Find</span>
                        <% } else if (product.tag) { %>
                            <span class="product-tag luxury-tag"><%= product.tag %></span>
                        <% } %>
                    </div>
                    <div class="product-details">
                        <span class="product-type"><%= product.type %></span>
                        <h3 class="product-name"><%= product.name %></h3>
                        <div class="price-container">
                            <span class="price">₹<%= product.price_inr.toLocaleString('en-IN') %></span>
                            <span class="price-usd">($<%= product.price_usd.toLocaleString() %>)</span>
                        </div>
                        <button class="add-to-bag-btn">Acquire Saree</button>
                    </div>
                </div>
                <% }); %>
            </div>
        </div>
    </section>

<%- include('partials/footer') %>
