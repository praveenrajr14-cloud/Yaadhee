<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sovereign Vault | Yadhee Administrative Dashboard</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Montserrat:wght@300;400;500;600;700&family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Figtree:wght@300;400;500;600;700&family=Merriweather:ital,wght@0,300;0,400;0,700;1,300&display=swap" rel="stylesheet">
    <!-- FontAwesome icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            --color-ivory: #FDFBF7;
            --color-cream-sidebar: #FAF8F5;
            --color-white: #FFFFFF;
            --color-gold: #C5A059;
            --color-gold-bright: #D4AF37;
            --color-gold-pale: #F1E5CB;
            --color-crimson: #7A0C1E;
            --color-crimson-deep: #5E0611;
            --color-dark-ruby: #1E0206;
            --color-charcoal: #2A2425;
            --color-gray-light: #F4F1EC;
            --color-gray-medium: #DDD9D2;
            --color-gray-dark: #8E877D;
            --font-heading: 'Cormorant Garamond', serif;
            --font-accent: 'Cinzel', serif;
            --font-body: 'Montserrat', sans-serif;
            --transition-smooth: all 0.4s cubic-bezier(0.25, 1, 0.5, 1);
            --border-gold-subtle: 1px solid rgba(197, 160, 89, 0.25);
            --border-gold-strong: 1px solid rgba(197, 160, 89, 0.5);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            outline: none;
        }

        body {
            background-color: var(--color-white);
            color: var(--color-charcoal);
            font-family: var(--font-body);
            font-weight: 300;
            line-height: 1.6;
            overflow-x: hidden;
        }

        /* Complete Dashboard Layout wrapper */
        .dashboard-wrapper {
            display: flex;
            min-height: 100vh;
        }

        /* 1. LEFT SIDEBAR ( tan/beige minimalist mockup ) */
        .sidebar {
            width: 280px;
            background-color: var(--color-cream-sidebar);
            border-right: 1px solid #EADCC9;
            display: flex;
            flex-direction: column;
            padding: 2.5rem 0;
            position: fixed;
            height: 100vh;
            z-index: 100;
        }

        .sidebar-logo-container {
            display: flex;
            align-items: center;
            gap: 0.8rem;
            padding: 0 2rem;
            margin-bottom: 3.5rem;
            text-decoration: none;
        }

        /* Abstract golden geometric interlocking logo vector */
        .logo-emblem {
            width: 38px;
            height: 38px;
            fill: none;
            stroke: var(--color-gold);
            stroke-width: 1.8;
        }

        .logo-text {
            display: flex;
            flex-direction: column;
        }

        .logo-main {
            font-family: var(--font-body);
            font-size: 1.1rem;
            font-weight: 700;
            letter-spacing: 0.1em;
            color: var(--color-charcoal);
            line-height: 1.1;
        }

        .logo-sub {
            font-family: var(--font-accent);
            font-size: 0.5rem;
            letter-spacing: 0.05em;
            color: var(--color-gray-dark);
            text-transform: uppercase;
        }

        .sidebar-nav {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
            padding: 0 1.2rem;
            flex-grow: 1;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 1rem;
            color: var(--color-charcoal);
            text-decoration: none;
            font-family: var(--font-body);
            font-size: 0.85rem;
            font-weight: 400;
            padding: 0.9rem 1.5rem;
            border-radius: 8px;
            transition: var(--transition-smooth);
            position: relative;
        }

        .nav-item i {
            font-size: 1.05rem;
            color: var(--color-gray-dark);
            width: 20px;
            text-align: center;
            transition: var(--transition-smooth);
        }

        /* Active Navigation item styling */
        .nav-item.active {
            background-color: var(--color-white);
            color: var(--color-charcoal);
            font-weight: 600;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.02);
        }

        .nav-item.active::before {
            content: '';
            position: absolute;
            left: 0;
            top: 25%;
            height: 50%;
            width: 4px;
            background-color: var(--color-gold);
            border-radius: 0 4px 4px 0;
        }

        .nav-item.active i {
            color: var(--color-gold);
        }

        .nav-item:hover:not(.active) {
            background-color: rgba(197, 160, 89, 0.05);
            color: var(--color-crimson);
        }

        .nav-item:hover i {
            color: var(--color-crimson);
        }

        /* Sidebar bottom vector line art */
        .sidebar-vector-lines {
            padding: 0 2rem;
            margin-top: auto;
            opacity: 0.65;
        }

        .sidebar-vector-lines svg {
            width: 100%;
            height: auto;
        }

        /* 2. MAIN SPACE AND TOPBAR */
        .main-content {
            margin-left: 280px;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            position: relative;
            background-color: var(--color-white);
        }

        /* Top Bar */
        .topbar {
            height: 90px;
            border-bottom: 1px solid #EADCC9;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 3.5rem;
            position: sticky;
            top: 0;
            background-color: var(--color-white);
            z-index: 90;
        }

        .search-box {
            display: flex;
            align-items: center;
            gap: 0.8rem;
            border: 1px solid #E5E0D8;
            border-radius: 8px;
            padding: 0.6rem 1.2rem;
            width: 320px;
            background-color: var(--color-white);
        }

        .search-box i {
            color: var(--color-gray-dark);
            font-size: 0.9rem;
        }

        .search-box input {
            border: none;
            background: none;
            font-family: var(--font-body);
            font-size: 0.85rem;
            color: var(--color-charcoal);
            width: 100%;
        }

        .profile-section {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .profile-text {
            display: flex;
            flex-direction: column;
            text-align: right;
        }

        .profile-name {
            font-family: var(--font-body);
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--color-charcoal);
        }

        .profile-info {
            font-family: var(--font-body);
            font-size: 0.7rem;
            color: var(--color-gray-dark);
        }

        .profile-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            overflow: hidden;
            border: 1px solid var(--color-gold);
        }

        .profile-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        /* 3. MAIN WORKSPACE TAB AREA */
        .workspace {
            padding: 3rem 3.5rem;
            padding-bottom: 6rem;
            flex-grow: 1;
        }

        .tab-panel {
            display: none;
            animation: fadeIn 0.4s ease forwards;
        }

        .tab-panel.active {
            display: block;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(8px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Header Row (Product Management title) */
        .page-header-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2.5rem;
        }

        .page-title {
            font-family: var(--font-heading);
            font-size: 2rem;
            font-weight: 400;
            color: var(--color-charcoal);
            letter-spacing: 0.02em;
        }

        /* Clean gold border card button */
        .add-new-btn {
            background-color: var(--color-white);
            border: 1.5px solid #C5A059;
            color: var(--color-charcoal);
            font-family: var(--font-body);
            font-size: 0.85rem;
            font-weight: 500;
            padding: 0.8rem 1.8rem;
            border-radius: 8px;
            cursor: pointer;
            box-shadow: 0 4px 15px rgba(197, 160, 89, 0.05);
            transition: var(--transition-smooth);
        }

        .add-new-btn:hover {
            background-color: #FAF6EE;
            border-color: var(--color-gold-bright);
            transform: translateY(-2px);
        }

        /* Stats & Sparkline Widget Row */
        .widget-row {
            display: grid;
            grid-template-columns: 280px 1fr;
            gap: 2rem;
            margin-bottom: 2.5rem;
        }

        .sales-overview-card {
            background-color: var(--color-white);
            border: 1px solid #EADCC9;
            border-radius: 12px;
            padding: 1.2rem 1.5rem;
            box-shadow: 0 4px 20px rgba(0,0,0,0.01);
            display: flex;
            flex-direction: column;
            gap: 0.6rem;
        }

        .overview-title {
            font-family: var(--font-body);
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--color-charcoal);
            letter-spacing: 0.02em;
        }

        .overview-chart {
            width: 100%;
            height: 60px;
        }

        .sparkline-svg {
            width: 100%;
            height: 100%;
        }

        /* Beige Header bar */
        .table-header-bar {
            background-color: #FAF6EE;
            border: 1px solid #EADCC9;
            border-radius: 8px;
            padding: 0.8rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
        }

        .col-left {
            display: flex;
            align-items: center;
            gap: 1.5rem;
        }

        .header-checkbox, .item-checkbox {
            accent-color: var(--color-gold);
            width: 16px;
            height: 16px;
            cursor: pointer;
        }

        .header-label {
            font-family: var(--font-body);
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--color-gray-dark);
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

        .col-right {
            padding-right: 4.5rem;
        }

        /* 2-COLUMN MASTERPIECE CARDS GRID */
        .products-cards-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
        }

        .masterpiece-card {
            background-color: var(--color-white);
            border: 1.2px solid #EADCC9;
            border-radius: 12px;
            padding: 1.2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.01);
            transition: var(--transition-smooth);
        }

        .masterpiece-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 25px rgba(197, 160, 89, 0.05);
            border-color: var(--color-gold);
        }

        .card-left {
            display: flex;
            align-items: center;
            gap: 1.2rem;
            flex-grow: 1;
        }

        .card-media {
            width: 70px;
            height: 70px;
            border-radius: 8px;
            overflow: hidden;
            border: 1px solid var(--color-gray-light);
            background-color: var(--color-cream-sidebar);
            flex-shrink: 0;
        }

        .card-media img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .card-info {
            display: flex;
            flex-direction: column;
            gap: 0.2rem;
        }

        .card-name {
            font-family: var(--font-body);
            font-size: 0.88rem;
            font-weight: 600;
            color: var(--color-charcoal);
        }

        .card-meta {
            display: flex;
            flex-direction: column;
            gap: 0.1rem;
            font-family: var(--font-body);
            font-size: 0.75rem;
            color: var(--color-gray-dark);
        }

        .meta-price {
            font-weight: 500;
            color: var(--color-charcoal);
        }

        .meta-alert {
            color: var(--color-crimson);
            font-weight: 600;
            font-size: 0.7rem;
            margin-top: 0.1rem;
            display: flex;
            align-items: center;
            gap: 0.2rem;
        }

        .card-right {
            display: flex;
            align-items: center;
            padding-right: 1rem;
        }

        .card-action-links {
            display: flex;
            align-items: center;
            gap: 1.5rem;
            font-family: var(--font-body);
            font-size: 0.8rem;
        }

        .edit-link {
            color: var(--color-gold);
            text-decoration: none;
            font-weight: 500;
            transition: var(--transition-smooth);
        }

        .edit-link:hover {
            color: var(--color-crimson);
        }

        .actions-dropdown {
            position: relative;
        }

        .actions-link {
            color: var(--color-gold);
            text-decoration: none;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 0.3rem;
            transition: var(--transition-smooth);
        }

        .actions-link:hover {
            color: var(--color-crimson);
        }

        .dropdown-menu-list {
            position: absolute;
            top: calc(100% + 8px);
            right: 0;
            background-color: var(--color-white);
            border: 1px solid #EADCC9;
            box-shadow: var(--shadow-luxury);
            border-radius: 8px;
            width: 140px;
            z-index: 10;
            display: none;
            overflow: hidden;
        }

        .dropdown-menu-list.active {
            display: block;
        }

        .menu-item-btn {
            background: none;
            border: none;
            width: 100%;
            padding: 0.6rem 1rem;
            font-family: var(--font-body);
            font-size: 0.75rem;
            text-align: left;
            cursor: pointer;
            color: var(--color-charcoal);
            display: flex;
            align-items: center;
            gap: 0.5rem;
            transition: var(--transition-smooth);
        }

        .menu-item-btn:hover {
            background-color: #FAF6EE;
            color: var(--color-crimson);
        }

        /* 4. FLOATING DEVELOPER PANEL (Payment Simulator) */
        .floating-payment-simulator {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 320px;
            background-color: var(--color-white);
            border: 1.5px solid #EADCC9;
            border-radius: 12px;
            box-shadow: 0 10px 35px rgba(0, 0, 0, 0.08);
            z-index: 1000;
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            gap: 1rem;
            animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        @keyframes slideUp {
            from { transform: translateY(40px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }

        .simulator-header {
            border-bottom: 1.2px solid #FAF6EE;
            padding-bottom: 0.6rem;
        }

        .sim-title {
            font-family: var(--font-body);
            font-size: 0.88rem;
            font-weight: 700;
            color: var(--color-charcoal);
            letter-spacing: 0.02em;
        }

        .simulator-body {
            display: flex;
            flex-direction: column;
            gap: 0.8rem;
        }

        .sim-group {
            display: flex;
            flex-direction: column;
        }

        .sim-select {
            border: 1px solid var(--color-gray-medium);
            border-radius: 6px;
            padding: 0.6rem;
            font-family: var(--font-body);
            font-size: 0.8rem;
            background-color: var(--color-white);
            color: var(--color-charcoal);
            cursor: pointer;
            width: 100%;
        }

        .sim-btn {
            background-color: var(--color-white);
            border: 1px solid var(--color-gold);
            color: var(--color-charcoal);
            border-radius: 6px;
            padding: 0.6rem;
            font-family: var(--font-body);
            font-size: 0.8rem;
            font-weight: 500;
            cursor: pointer;
            transition: var(--transition-smooth);
            width: 100%;
        }

        .sim-btn:hover {
            background-color: #FAF6EE;
            border-color: var(--color-gold-bright);
        }

        .sim-links {
            display: flex;
            flex-direction: column;
            gap: 0.4rem;
            border-top: 1px solid #FAF6EE;
            padding-top: 0.6rem;
        }

        .sim-link {
            font-family: var(--font-body);
            font-size: 0.72rem;
            color: var(--color-gray-dark);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 0.4rem;
            transition: var(--transition-smooth);
        }

        .sim-link:hover {
            color: var(--color-gold);
        }

        /* 5. TABS: SECURE DISPATCHES (ORDERS) */
        .luxury-table-wrapper {
            background-color: var(--color-white);
            border: 1px solid #EADCC9;
            border-radius: 12px;
            padding: 1.5rem;
            overflow-x: auto;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.01);
        }

        .luxury-table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
            font-size: 0.85rem;
        }

        .luxury-table th {
            font-family: var(--font-body);
            font-weight: 600;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            color: var(--color-gold);
            padding: 1rem 1.2rem;
            border-bottom: 2px solid var(--color-gray-light);
            font-size: 0.72rem;
        }

        .luxury-table td {
            padding: 1.1rem 1.2rem;
            border-bottom: 1px solid var(--color-gray-light);
            color: var(--color-charcoal);
        }

        .luxury-table tr:hover {
            background-color: #FAF9F6;
        }

        .status-badge {
            font-size: 0.65rem;
            font-weight: 600;
            padding: 0.3rem 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            display: inline-block;
            border-radius: 4px;
        }
        .status-badge.Pending { background: #FFF9E6; color: #D48E00; border: 1px solid #FFE499; }
        .status-badge.Processing { background: #E6F0FF; color: #0066CC; border: 1px solid #99CCFF; }
        .status-badge.Shipped { background: #F0F9EB; color: #67C23A; border: 1px solid #C2E7B0; }
        .status-badge.Delivered { background: #F5F7FA; color: #909399; border: 1px solid #DCDFE6; }

        .btn-action-group {
            display: flex;
            gap: 0.4rem;
        }

        .action-btn-sm {
            background: none;
            border: 1px solid var(--color-gray-medium);
            padding: 0.4rem 0.8rem;
            font-size: 0.72rem;
            font-family: var(--font-body);
            cursor: pointer;
            color: var(--color-charcoal);
            border-radius: 4px;
            transition: var(--transition-smooth);
        }

        .action-btn-sm:hover {
            border-color: var(--color-gold);
            color: var(--color-gold);
        }

        /* 6. CRUD DIALOGS POPUPS */
        .admin-modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(30, 2, 6, 0.6);
            z-index: 3000;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: var(--transition-smooth);
        }

        .admin-modal-overlay.active {
            opacity: 1;
            pointer-events: auto;
        }

        .admin-modal {
            background-color: var(--color-white);
            border: 1.5px solid var(--color-gold);
            border-radius: 12px;
            width: 90%;
            max-width: 650px;
            max-height: 85vh;
            overflow-y: auto;
            padding: 2.5rem;
            box-shadow: var(--shadow-luxury);
            position: relative;
        }

        .modal-close-btn {
            position: absolute;
            top: 1.2rem;
            right: 1.5rem;
            background: none;
            border: none;
            font-size: 1.3rem;
            cursor: pointer;
            color: var(--color-gray-dark);
            transition: var(--transition-smooth);
        }

        .modal-close-btn:hover {
            color: var(--color-crimson);
        }

        .form-title {
            font-family: var(--font-heading);
            font-size: 1.45rem;
            color: var(--color-crimson-deep);
            margin-bottom: 1.8rem;
            border-bottom: 1px solid var(--color-gray-light);
            padding-bottom: 0.8rem;
        }

        .dashboard-form {
            width: 100%;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
            margin-bottom: 1.5rem;
        }

        .form-group {
            margin-bottom: 1.5rem;
            display: flex;
            flex-direction: column;
            gap: 0.4rem;
        }

        .form-group label {
            font-family: var(--font-body);
            font-size: 0.72rem;
            font-weight: 600;
            letter-spacing: 0.05em;
            color: var(--color-gold);
            text-transform: uppercase;
        }

        .form-group input, 
        .form-group select, 
        .form-group textarea {
            border: 1px solid var(--color-gray-medium);
            border-radius: 6px;
            padding: 0.8rem 1rem;
            font-family: var(--font-body);
            font-size: 0.85rem;
            background-color: var(--color-ivory);
            transition: var(--transition-smooth);
        }

        .form-group input:focus, 
        .form-group select:focus, 
        .form-group textarea:focus {
            border-color: var(--color-gold);
            background-color: var(--color-white);
        }

        .specs-editor-container {
            border: 1px solid var(--color-gray-light);
            padding: 1.5rem;
            border-radius: 8px;
            margin-bottom: 1.5rem;
        }

        .spec-editor-title {
            font-family: var(--font-body);
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--color-gold);
            margin-bottom: 1rem;
            text-transform: uppercase;
        }

        .spec-row {
            display: grid;
            grid-template-columns: 1fr 1.2fr 40px;
            gap: 0.8rem;
            margin-bottom: 0.8rem;
            align-items: center;
        }

        .remove-spec-btn {
            background: none;
            border: 1px solid var(--color-gray-medium);
            height: 38px;
            border-radius: 4px;
            color: var(--color-gray-dark);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: var(--transition-smooth);
        }

        .remove-spec-btn:hover {
            border-color: var(--color-crimson);
            color: var(--color-crimson);
        }

        .add-spec-btn {
            background: none;
            border: 1px dashed var(--color-gold);
            color: var(--color-gold);
            border-radius: 4px;
            padding: 0.5rem 1rem;
            font-size: 0.75rem;
            font-family: var(--font-body);
            cursor: pointer;
            width: 100%;
            transition: var(--transition-smooth);
        }

        .add-spec-btn:hover {
            background-color: rgba(197, 160, 89, 0.05);
        }

        /* Order items modal views */
        .order-modal-details {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            margin-bottom: 2rem;
            border: 1px solid var(--color-gray-light);
            padding: 1.5rem;
            border-radius: 8px;
        }

        .order-details-meta {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 1.2rem;
            border-bottom: 1px solid var(--color-gray-light);
            padding-bottom: 1rem;
            margin-bottom: 1rem;
            font-size: 0.8rem;
        }

        .meta-label {
            font-weight: 600;
            color: var(--color-gold);
            text-transform: uppercase;
            font-size: 0.7rem;
            display: block;
            margin-bottom: 0.2rem;
        }

        .order-modal-item {
            display: flex;
            align-items: center;
            gap: 1.2rem;
            border-bottom: 1px dotted var(--color-gray-medium);
            padding-bottom: 0.8rem;
        }

        .order-modal-item:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }
    </style>
</head>
<body>

    <div class="dashboard-wrapper">
        
        <!-- Sidebar Navigation (left) -->
        <aside class="sidebar">
            <a href="/" class="sidebar-logo-container">
                <!-- Golden abstract interlocking geometric vector logo -->
                <svg class="logo-emblem" viewBox="0 0 100 100">
                    <path d="M20 50 Q35 25 50 50 T80 50" fill="none" />
                    <path d="M50 20 Q50 50 80 80" fill="none" />
                    <path d="M50 20 Q50 50 20 80" fill="none" />
                    <circle cx="50" cy="50" r="4" fill="var(--color-gold-bright)"></circle>
                </svg>
                <div class="logo-text">
                    <span class="logo-main">MODERN</span>
                    <span class="logo-sub">SAREE & JEWELRY CO.</span>
                </div>
            </a>
            
            <nav class="sidebar-nav">
                <a href="#products" class="nav-item active" onclick="switchNavTab(event, 'productsTab')">
                    <i class="fa-solid fa-cubes"></i> Products
                </a>
                <a href="#orders" class="nav-item" onclick="switchNavTab(event, 'ordersTab')">
                    <i class="fa-solid fa-receipt"></i> Orders
                </a>
                <a href="#bookings" class="nav-item" onclick="switchNavTab(event, 'bookingsTab')">
                    <i class="fa-solid fa-calendar-check"></i> Atelier Registry
                </a>
                <a href="#subs" class="nav-item" onclick="switchNavTab(event, 'subsTab')">
                    <i class="fa-solid fa-users"></i> Patrons List
                </a>
                <a href="#marketing" class="nav-item" onclick="switchNavTab(event, 'marketingTab')">
                    <i class="fa-solid fa-envelope-open-text"></i> Recovery Vault
                </a>
            </nav>
            
            <!-- Bottom Chevron Vector Lines Art -->
            <div class="sidebar-vector-lines">
                <svg viewBox="0 0 200 100" fill="none" stroke="#E5DEC9" stroke-width="1.2">
                    <path d="M0,80 L50,40 L100,80 L150,40 L200,80" />
                    <path d="M0,90 L50,50 L100,90 L150,50 L200,90" />
                </svg>
            </div>
        </aside>

        <!-- Main Workspace (right) -->
        <div class="main-content">
            
            <!-- Top bar -->
            <header class="topbar">
                <div class="search-box">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input type="text" id="dashboardSearch" placeholder="Search Masterpieces..." onkeyup="filterCardsGrid()">
                </div>
                
                <div class="profile-section">
                    <div class="profile-text">
                        <span class="profile-name">Nanhan Name</span>
                        <span class="profile-info">Poster info</span>
                    </div>
                    <div class="profile-avatar">
                        <!-- Profile Avatar placeholder -->
                        <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?q=80&w=150&auto=format&fit=crop" alt="Admin Curator Avatar">
                    </div>
                </div>
            </header>

            <main class="workspace">
                
                <!-- ============================================================= -->
                <!-- TAB PANEL: PRODUCTS MANAGEMENT CARD GRID -->
                <!-- ============================================================= -->
                <section id="productsTab" class="tab-panel active">
                    
                    <!-- Header Row -->
                    <div class="page-header-row">
                        <h1 class="page-title">Product Management</h1>
                        
                        <button class="add-new-btn" onclick="openAddProductModal()">
                            Add New Arrival
                        </button>
                    </div>

                    <!-- Curated stats widgets -->
                    <div class="widget-row" style="grid-template-columns: 280px 1fr !important;">
                        <!-- Dynamic Smooth Sparkline Sales Overview -->
                        <div class="sales-overview-card">
                            <span class="overview-title">Sales Overview</span>
                            <div class="overview-chart">
                                <svg class="sparkline-svg" viewBox="0 0 200 65" preserveAspectRatio="none">
                                    <defs>
                                        <linearGradient id="chartGradient" x1="0" y1="0" x2="0" y2="1">
                                            <stop offset="0%" stop-color="#C5A059" stop-opacity="0.35"/>
                                            <stop offset="100%" stop-color="#C5A059" stop-opacity="0"/>
                                        </linearGradient>
                                    </defs>
                                    <path d="M 0 55 Q 30 20 60 45 T 120 18 T 180 32 L 200 12 L 200 65 L 0 65 Z" fill="url(#chartGradient)"></path>
                                    <path d="M 0 55 Q 30 20 60 45 T 120 18 T 180 32 L 200 12" fill="none" stroke="#C5A059" stroke-width="2.5"></path>
                                    <circle cx="60" cy="45" r="3.5" fill="#7A0C1E"></circle>
                                    <circle cx="120" cy="18" r="3.5" fill="#7A0C1E"></circle>
                                    <circle cx="200" cy="12" r="3.5" fill="#7A0C1E"></circle>
                                </svg>
                            </div>
                        </div>

                        <!-- Configurable Low Stock Alerts Panel next to it -->
                        <div class="sales-overview-card" style="display: flex; flex-direction: column; gap: 0.6rem; min-height: 100px;">
                            <span class="overview-title" style="display: flex; align-items: center; gap: 0.4rem;">
                                <i class="fa-solid fa-triangle-exclamation" style="color: var(--color-crimson);"></i> Low Stock Alerts Panel
                                <span style="font-size: 0.7rem; font-weight: normal; color: var(--color-gray-dark); margin-left: auto;">Threshold: &lt; <%= lowStockThreshold %> items</span>
                            </span>
                            <div style="display: flex; flex-direction: column; gap: 0.5rem; max-height: 80px; overflow-y: auto; padding-right: 0.5rem;">
                                <% 
                                   let lowStockItems = products.filter(p => p.stock_quantity < lowStockThreshold && p.is_active === 1);
                                   if (lowStockItems.length === 0) { 
                                %>
                                    <div style="font-size: 0.72rem; color: var(--color-gray-dark); font-style: italic;">All masterpieces sufficiently stocked in vault.</div>
                                <% } else { %>
                                    <% lowStockItems.forEach(function(lp) { %>
                                        <div style="display: flex; justify-content: space-between; align-items: center; font-size: 0.75rem; border-bottom: 1px dashed var(--color-gray-medium); padding-bottom: 0.2rem;">
                                            <span style="font-weight: 500; color: var(--color-charcoal);"><%= lp.name %> (<%= lp.id %>)</span>
                                            <span style="background-color: var(--color-crimson); color: white; padding: 0.1rem 0.4rem; border-radius: 4px; font-weight: 600; font-size: 0.65rem;">Stock: <%= lp.stock_quantity %> left</span>
                                        </div>
                                    <% }); %>
                                <% } %>
                            </div>
                        </div>
                    </div>

                    <!-- Products Table beige header bar -->
                    <div class="table-header-bar">
                        <div class="col-left">
                            <input type="checkbox" class="header-checkbox" onclick="toggleSelectAllProducts(this)">
                            <span class="header-label">Product</span>
                        </div>
                        <div class="col-right">
                            <span class="header-label">Actions</span>
                        </div>
                    </div>

                    <!-- Dynamic Masterpiece 2-column cards grid layout -->
                    <div class="products-cards-grid" id="productsCardsGrid">
                        <% products.forEach(function(p) { %>
                        <div class="masterpiece-card" data-id="<%= p.id %>" data-name="<%= p.name.toLowerCase() %>" data-type="<%= p.type.toLowerCase() %>">
                            <div class="card-left">
                                <input type="checkbox" class="item-checkbox">
                                <div class="card-media">
                                    <img src="/<%= p.image_url %>" alt="<%= p.name %>">
                                </div>
                                <div class="card-info">
                                    <h4 class="card-name"><%= p.name %></h4>
                                    <div class="card-meta">
                                        <span class="meta-stock">Stock: <%= p.stock_quantity %></span>
                                        <span class="meta-price">Price: <%= p.price_inr %> INR</span>
                                        <% if (p.stock_quantity < lowStockThreshold) { %>
                                            <span class="meta-alert" style="color: var(--color-crimson); font-weight: 600; font-size: 0.7rem; margin-top: 0.1rem; display: flex; align-items: center; gap: 0.2rem;">
                                                <i class="fa-solid fa-triangle-exclamation"></i> Low Stock Alert (<%= p.stock_quantity %> left)
                                            </span>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                            <div class="card-right">
                                <div class="card-action-links">
                                    <a href="#edit" class="edit-link" onclick='openEditProductModal(<%- JSON.stringify(p) %>)'>Edit</a>
                                    <div class="actions-dropdown">
                                        <a href="#actions" class="actions-link" onclick="toggleDropdownMenu(event, this)">Actions <i class="fa-solid fa-chevron-down"></i></a>
                                        <div class="dropdown-menu-list">
                                            <% if (p.is_active === 1) { %>
                                            <form action="/admin/products/delete/<%= p.id %>" method="POST" onsubmit="return confirm('Are you sure you want to hide this masterpiece?')" style="display:block; width:100%;">
                                                <button type="submit" class="menu-item-btn"><i class="fa-solid fa-eye-slash"></i> Hide Item</button>
                                            </form>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <% }); %>
                    </div>
                </section>

                <!-- ============================================================= -->
                <!-- TAB PANEL: SECURE DISPATCHES (ORDERS) -->
                <!-- ============================================================= -->
                <section id="ordersTab" class="tab-panel">
                    <div class="page-header-row">
                        <h1 class="page-title">Valued Dispatches Registry</h1>
                    </div>

                    <div class="luxury-table-wrapper">
                        <table class="luxury-table">
                            <thead>
                                <tr>
                                    <th>Order ID</th>
                                    <th>Patron Details</th>
                                    <th>Transit Address</th>
                                    <th>Value (INR)</th>
                                    <th>Fulfillment</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% orders.forEach(function(o) { %>
                                <tr>
                                    <td><strong>#<%= o.id %></strong></td>
                                    <td>
                                        <strong><%= o.customer_name %></strong><br>
                                        <span style="font-size: 0.72rem; color: var(--color-gray-dark);"><%= o.customer_email %> | <%= o.customer_phone %></span>
                                    </td>
                                    <td><span style="font-size: 0.8rem;"><%= o.shipping_address %></span></td>
                                    <td><strong>₹<%= o.total_price_inr.toLocaleString('en-IN') %></strong></td>
                                    <td><span class="status-badge <%= o.status %>"><%= o.status %></span></td>
                                    <td>
                                        <div class="btn-action-group">
                                            <button class="action-btn-sm" onclick="viewOrderDetails(<%= o.id %>)">View Items <i class="fa-solid fa-box-open"></i></button>
                                            <button class="action-btn-sm" onclick="openStatusUpdateModal(<%= o.id %>, '<%= o.status %>')">Status <i class="fa-solid fa-truck-ramp-box"></i></button>
                                            <% if (o.invoice_path) { %>
                                                <a href="/admin/orders/invoice/<%= o.id %>" target="_blank" class="action-btn-sm" style="text-decoration: none;"><i class="fa-solid fa-file-pdf"></i> Invoice</a>
                                            <% } %>
                                        </div>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                </section>

                <!-- ============================================================= -->
                <!-- TAB PANEL: VIRTUAL ATELIER BOOKINGS -->
                <!-- ============================================================= -->
                <section id="bookingsTab" class="tab-panel">
                    <div class="page-header-row">
                        <h1 class="page-title">Bespoke Atelier Design Appointments</h1>
                    </div>

                    <div class="luxury-table-wrapper">
                        <table class="luxury-table">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Client Profile</th>
                                    <th>Craft Domain Interest</th>
                                    <th>Preferences Prose</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% bookings.forEach(function(b) { %>
                                <tr>
                                    <td><strong>#<%= b.id %></strong></td>
                                    <td>
                                        <strong><%= b.client_name %></strong><br>
                                        <span style="font-size: 0.72rem; color: var(--color-gray-dark);"><%= b.client_email %></span>
                                    </td>
                                    <td>
                                        <span style="font-size: 0.8rem; font-weight: 500;">
                                            <% if (b.interest_type === 'bridal_saree') { %>
                                                Bespoke Bridal Saree (Kanchipuram)
                                            <% } else if (b.interest_type === 'temple_jewelry') { %>
                                                Heirloom Temple Gold Design
                                            <% } else { %>
                                                Complete Trousseau Curation
                                            <% } %>
                                        </span>
                                    </td>
                                    <td><p style="font-size: 0.78rem; max-width: 250px; color: var(--color-charcoal);"><%= b.message || 'No preferences detailed.' %></p></td>
                                    <td><span class="status-badge <%= b.status === 'Pending' ? 'Pending' : (b.status === 'Scheduled' ? 'Processing' : 'Delivered') %>"><%= b.status %></span></td>
                                    <td>
                                        <button class="action-btn-sm" onclick="openBookingStatusModal(<%= b.id %>, '<%= b.status %>')">Set Status <i class="fa-solid fa-calendar-check"></i></button>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                </section>

                <!-- ============================================================= -->
                <!-- TAB PANEL: PATRONS NEWSLETTER CHRONICLES -->
                <!-- ============================================================= -->
                <section id="subsTab" class="tab-panel">
                    <div class="page-header-row">
                        <h1 class="page-title">Patron Chronicles Inner Circle</h1>
                    </div>

                    <div class="luxury-table-wrapper" style="max-width: 600px; margin: 0 auto;">
                        <table class="luxury-table">
                            <thead>
                                <tr>
                                    <th>Database ID</th>
                                    <th>Patron Email Portal</th>
                                    <th>Registry Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% subscribers.forEach(function(s) { %>
                                <tr>
                                    <td><strong>#<%= s.id %></strong></td>
                                    <td><strong><%= s.email %></strong></td>
                                    <td><span style="font-size: 0.75rem;"><%= new Date(s.created_at).toLocaleString() %></span></td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                </section>

                <!-- ============================================================= -->
                <!-- TAB PANEL: MARKETING RECOVERY VAULT (ABANDONED CARTS) -->
                <!-- ============================================================= -->
                <section id="marketingTab" class="tab-panel">
                    <div class="page-header-row">
                        <h1 class="page-title">Marketing Recovery Vault (Abandoned Carts)</h1>
                    </div>

                    <div class="luxury-table-wrapper">
                        <table class="luxury-table">
                            <thead>
                                <tr>
                                    <th>Cart ID</th>
                                    <th>Patron Profile</th>
                                    <th>Cart Contents</th>
                                    <th>Total Value</th>
                                    <th>Abandon Date</th>
                                    <th>Recovery State</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% abandonedCarts.forEach(function(ac) { %>
                                <tr>
                                    <td><strong>#<%= ac.id %></strong></td>
                                    <td>
                                        <strong><%= ac.customer_name || 'Anonymous Patron' %></strong><br>
                                        <span style="font-size: 0.72rem; color: var(--color-gray-dark);"><%= ac.customer_email %> | <%= ac.customer_phone || 'No phone' %></span>
                                    </td>
                                    <td>
                                        <span style="font-size: 0.78rem; line-height: 1.4;">
                                            <% 
                                               let items = [];
                                               try {
                                                   items = JSON.parse(ac.cart_data || '[]');
                                               } catch(e) {}
                                               items.forEach(function(ci) { 
                                            %>
                                               • <%= ci.name || ci.id %> (Qty: <%= ci.qty %>)<br>
                                            <% }); %>
                                        </span>
                                    </td>
                                    <td><strong>₹<%= ac.total_price_inr.toLocaleString('en-IN') %></strong></td>
                                    <td><span style="font-size: 0.75rem;"><%= new Date(ac.created_at).toLocaleString() %></span></td>
                                    <td>
                                        <% if (ac.recovered === 1) { %>
                                            <span class="status-badge Shipped" style="background: #E6F7FF; color: #1890FF; border: 1px solid #91D5FF;">Discount Sent</span>
                                        <% } else if (ac.recovered === 2) { %>
                                            <span class="status-badge Delivered">Purchased</span>
                                        <% } else { %>
                                            <span class="status-badge Pending">Abandoned</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <% if (ac.recovered === 0) { %>
                                            <button class="action-btn-sm" onclick="simulateDiscountRecovery(<%= ac.id %>, this)" style="background-color: var(--color-white); border-color: var(--color-gold); font-weight: 500;">
                                                Simulate 10% Discount <i class="fa-solid fa-paper-plane"></i>
                                            </button>
                                        <% } else if (ac.recovered === 1) { %>
                                            <a href="/assets/emails/recovery-<%= ac.id %>.html" target="_blank" class="action-btn-sm" style="text-decoration:none;"><i class="fa-regular fa-envelope"></i> Preview Recovery Email</a>
                                        <% } else { %>
                                            <span style="font-size: 0.72rem; color: var(--color-gray-dark); font-style: italic;">Customer Converted</span>
                                        <% } %>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                </section>

            </main>

            <!-- ============================================================= -->
            <!-- FLOATING DEVELOPER PANEL (Payment Simulator matching mockup) -->
            <!-- ============================================================= -->
            <div class="floating-payment-simulator">
                <div class="simulator-header">
                    <span class="sim-title">Payment Simulator</span>
                </div>
                <div class="simulator-body">
                    <div class="sim-group">
                        <select id="simForceOutcome" class="sim-select">
                            <option value="success">Simulate Payment Success</option>
                            <option value="failure">Simulate Payment Failure</option>
                        </select>
                    </div>
                    
                    <button class="sim-btn" onclick="runSimulatedTransaction()">
                        Run Mock Transaction
                    </button>
                    
                    <div class="sim-links">
                        <% if (orders && orders.length > 0) { %>
                            <a href="/admin/orders/invoice/<%= orders[0].id %>" target="_blank" class="sim-link" id="simLastInvoiceLink"><i class="fa-regular fa-file-pdf"></i> Generate Sample Invoice PDF</a>
                            <a href="/assets/emails/email-<%= orders[0].id %>.html" target="_blank" class="sim-link" id="simLastEmailLink"><i class="fa-regular fa-envelope"></i> Email Simulation</a>
                        <% } else { %>
                            <a href="#" class="sim-link" onclick="alert('No orders logged in database yet to preview invoices.')"><i class="fa-regular fa-file-pdf"></i> Generate Sample Invoice PDF</a>
                            <a href="#" class="sim-link" onclick="alert('No emails logged locally yet to preview.')"><i class="fa-regular fa-envelope"></i> Email Simulation</a>
                        <% } %>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!-- ============================================================= -->
    <!-- DIALOGS AND CRUD POPUPS -->
    <!-- ============================================================= -->

    <!-- Add Product Modal -->
    <div class="admin-modal-overlay" id="addProductModal">
        <div class="admin-modal">
            <button class="modal-close-btn" onclick="closeModal('addProductModal')"><i class="fa-solid fa-xmark"></i></button>
            <h3 class="form-title">Vault a New Masterpiece</h3>
            <form action="/admin/products/add" method="POST" enctype="multipart/form-data" class="dashboard-form">
                <div class="form-row">
                    <div class="form-group">
                        <label for="id">Masterpiece ID (Unique Key)</label>
                        <input type="text" name="id" required placeholder="e.g. s4 or j4">
                    </div>
                    <div class="form-group">
                        <label for="category">Category</label>
                        <select name="category" required onchange="updateSubcategories(this, 'add_subcat')">
                            <option value="saree">Saree (Weaves)</option>
                            <option value="jewel">Jewel (Ornaments)</option>
                        </select>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="subcategory">Subcategory / Filter Tag</label>
                        <select name="subcategory" id="add_subcat" required>
                            <option value="kanchipuram">Kanchipuram Silks</option>
                            <option value="banarasi">Banarasi Satins</option>
                            <option value="organza">Regal Organzas</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="type">Craft Type / Fabric</label>
                        <input type="text" name="type" required placeholder="e.g. Kanchipuram Silk or Antique Temple Gold">
                    </div>
                </div>

                <div class="form-group">
                    <label for="name">Product Display Name</label>
                    <input type="text" name="name" required placeholder="e.g. Swarna Golden Filigree Set">
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="price_inr">Price in Sovereign INR</label>
                        <input type="number" name="price_inr" required placeholder="245000">
                    </div>
                    <div class="form-group">
                        <label for="price_usd">Price in USD ($)</label>
                        <input type="number" name="price_usd" required placeholder="2950">
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="tag">Luxury Card Label Tag</label>
                        <input type="text" name="tag" placeholder="e.g. Royal Bestseller (Can leave blank)">
                    </div>
                    <div class="form-group">
                        <label for="stock_quantity">Initial Stock Quantity</label>
                        <input type="number" name="stock_quantity" min="0" required value="5" placeholder="5">
                    </div>
                </div>
                <div class="form-group">
                    <label for="product_image">Masterpiece Close-up Image Asset</label>
                    <input type="file" name="product_image" accept="image/*">
                </div>

                <div class="form-group">
                    <label for="description">Artisan Description Prose</label>
                    <textarea name="description" rows="3" required placeholder="Detail the weaver details, metals, gems, and court mythology context..."></textarea>
                </div>

                <div class="specs-editor-container">
                    <div class="spec-editor-title">Product Technical Specifications</div>
                    <div id="add_specs_fields">
                        <div class="spec-row">
                            <input type="text" name="spec_keys" placeholder="Key (e.g. Craftsmanship)" required>
                            <input type="text" name="spec_values" placeholder="Value (e.g. Generational Handloom)" required>
                            <button type="button" class="remove-spec-btn" onclick="removeSpecRow(this)"><i class="fa-solid fa-trash"></i></button>
                        </div>
                    </div>
                    <div class="add-spec-btn-row">
                        <button type="button" class="add-spec-btn" onclick="addSpecRow('add_specs_fields')"><i class="fa-solid fa-plus"></i> Add Spec Row</button>
                    </div>
                </div>

                <button type="submit" class="add-new-btn" style="width: 100%; padding: 1rem; background-color: var(--color-crimson); color: white; border-color: var(--color-crimson);">Transmit New Masterpiece Entry <i class="fa-solid fa-upload"></i></button>
            </form>
        </div>
    </div>

    <!-- Edit Product Modal -->
    <div class="admin-modal-overlay" id="editProductModal">
        <div class="admin-modal">
            <button class="modal-close-btn" onclick="closeModal('editProductModal')"><i class="fa-solid fa-xmark"></i></button>
            <h3 class="form-title">Edit Masterpiece Vault Registry</h3>
            <form id="editProductForm" action="" method="POST" enctype="multipart/form-data" class="dashboard-form">
                <div class="form-row">
                    <div class="form-group">
                        <label>Masterpiece ID (Static key)</label>
                        <input type="text" id="edit_id" disabled style="background-color: var(--color-gray-light); color: var(--color-gray-dark);">
                    </div>
                    <div class="form-group">
                        <label for="category">Category</label>
                        <select name="category" id="edit_cat" required onchange="updateSubcategories(this, 'edit_subcat')">
                            <option value="saree">Saree (Weaves)</option>
                            <option value="jewel">Jewel (Ornaments)</option>
                        </select>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="subcategory">Subcategory / Filter Tag</label>
                        <select name="subcategory" id="edit_subcat" required>
                            <option value="kanchipuram">Kanchipuram Silks</option>
                            <option value="banarasi">Banarasi Satins</option>
                            <option value="organza">Regal Organzas</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="type">Craft Type / Fabric</label>
                        <input type="text" name="type" id="edit_type" required>
                    </div>
                </div>

                <div class="form-group">
                    <label for="name">Product Display Name</label>
                    <input type="text" name="name" id="edit_name" required>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="price_inr">Price in Sovereign INR</label>
                        <input type="number" name="price_inr" id="edit_price_inr" required>
                    </div>
                    <div class="form-group">
                        <label for="price_usd">Price in USD ($)</label>
                        <input type="number" name="price_usd" id="edit_price_usd" required>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="tag">Luxury Card Label Tag</label>
                        <input type="text" name="tag" id="edit_tag">
                    </div>
                    <div class="form-group">
                        <label for="stock_quantity">Update Stock Quantity</label>
                        <input type="number" name="stock_quantity" id="edit_stock" min="0" required placeholder="5">
                    </div>
                </div>
                <div class="form-group">
                    <label for="product_image">Replace Masterpiece Close-up Image (Optional)</label>
                    <input type="file" name="product_image" accept="image/*">
                </div>

                <div class="form-group">
                    <label for="description">Artisan Description Prose</label>
                    <textarea name="description" id="edit_desc" rows="3" required></textarea>
                </div>

                <div class="specs-editor-container">
                    <div class="spec-editor-title">Product Technical Specifications</div>
                    <div id="edit_specs_fields"></div>
                    <div class="add-spec-btn-row">
                        <button type="button" class="add-spec-btn" onclick="addSpecRow('edit_specs_fields')"><i class="fa-solid fa-plus"></i> Add Spec Row</button>
                    </div>
                </div>

                <button type="submit" class="add-new-btn" style="width: 100%; padding: 1rem; background-color: var(--color-crimson); color: white; border-color: var(--color-crimson);">Confirm Vault Changes <i class="fa-solid fa-file-signature"></i></button>
            </form>
        </div>
    </div>

    <!-- View Order Details Modal -->
    <div class="admin-modal-overlay" id="orderDetailsModal">
        <div class="admin-modal" style="max-width: 600px;">
            <button class="modal-close-btn" onclick="closeModal('orderDetailsModal')"><i class="fa-solid fa-xmark"></i></button>
            <h3 class="form-title">Secured Dispatch Items</h3>
            
            <div id="orderItemsLoading" style="text-align: center; padding: 2rem;">
                <i class="fa-solid fa-circle-notch fa-spin" style="font-size: 2rem; color: var(--color-gold);"></i>
                <p style="margin-top: 0.5rem; font-size: 0.85rem; color: var(--color-gray-dark);">Decrypting items from ledger...</p>
            </div>

            <div id="orderItemsWrapper" style="display: none;">
                <div class="order-modal-details" id="orderModalDetailsMeta"></div>
                <div id="orderModalItemsList" style="display: flex; flex-direction: column; gap: 1rem;"></div>
            </div>
        </div>
    </div>

    <!-- Update Order Status Modal -->
    <div class="admin-modal-overlay" id="orderStatusModal">
        <div class="admin-modal" style="max-width: 400px;">
            <button class="modal-close-btn" onclick="closeModal('orderStatusModal')"><i class="fa-solid fa-xmark"></i></button>
            <h3 class="form-title">Update Dispatch status</h3>
            <form id="orderStatusForm" action="" method="POST" class="dashboard-form">
                <div class="form-group">
                    <label for="status">Fulfillment Status</label>
                    <select name="status" id="order_status_select" required>
                        <option value="Pending">Pending Validation</option>
                        <option value="Processing">Atelier Custom stitching</option>
                        <option value="Shipped">Shipped (Insured Dispatch)</option>
                        <option value="Delivered">Delivered & fitting closed</option>
                    </select>
                </div>
                <button type="submit" class="add-new-btn" style="width: 100%;">Commit Status Change <i class="fa-solid fa-clipboard-check"></i></button>
            </form>
        </div>
    </div>

    <!-- Update Booking Status Modal -->
    <div class="admin-modal-overlay" id="bookingStatusModal">
        <div class="admin-modal" style="max-width: 400px;">
            <button class="modal-close-btn" onclick="closeModal('bookingStatusModal')"><i class="fa-solid fa-xmark"></i></button>
            <h3 class="form-title">Set Consultation Status</h3>
            <form id="bookingStatusForm" action="" method="POST" class="dashboard-form">
                <div class="form-group">
                    <label for="status">Appointment Status</label>
                    <select name="status" id="booking_status_select" required>
                        <option value="Pending">Pending Registry</option>
                        <option value="Scheduled">Appointment Scheduled</option>
                        <option value="Completed">Consultation Completed</option>
                    </select>
                </div>
                <button type="submit" class="add-new-btn" style="width: 100%;">Set Appointment Status <i class="fa-solid fa-user-check"></i></button>
            </form>
        </div>
    </div>

    <!-- JS Controllers -->
    <script>
        // Switch Tab Navigation
        function switchNavTab(evt, tabName) {
            evt.preventDefault();
            const panels = document.querySelectorAll('.tab-panel');
            panels.forEach(panel => panel.classList.remove('active'));

            const navItems = document.querySelectorAll('.nav-item');
            navItems.forEach(item => item.classList.remove('active'));

            document.getElementById(tabName).classList.add('active');
            evt.currentTarget.classList.add('active');
        }

        // Subcategory options matching category
        const subcatOptions = {
            saree: [
                { val: 'kanchipuram', label: 'Kanchipuram Silks' },
                { val: 'banarasi', label: 'Banarasi Satins' },
                { val: 'organza', label: 'Regal Organzas' }
            ],
            jewel: [
                { val: 'temple', label: 'Temple Gold' },
                { val: 'polki', label: 'Jadau Polki Gems' },
                { val: 'bangles', label: 'Filigree Bangles' }
            ]
        };

        function updateSubcategories(catSelect, subcatId, defaultVal = '') {
            const val = catSelect.value;
            const subcatSelect = document.getElementById(subcatId);
            subcatSelect.innerHTML = '';
            
            if (subcatOptions[val]) {
                subcatOptions[val].forEach(opt => {
                    const el = document.createElement('option');
                    el.value = opt.val;
                    el.textContent = opt.label;
                    if (opt.val === defaultVal) el.selected = true;
                    subcatSelect.appendChild(el);
                });
            }
        }

        // Specs builder
        function addSpecRow(containerId, key = '', val = '') {
            const container = document.getElementById(containerId);
            const row = document.createElement('div');
            row.className = 'spec-row';
            row.innerHTML = `
                <input type="text" name="spec_keys" placeholder="Key (e.g. Material)" required value="${key}">
                <input type="text" name="spec_values" placeholder="Value (e.g. Silk)" required value="${val}">
                <button type="button" class="remove-spec-btn" onclick="removeSpecRow(this)"><i class="fa-solid fa-trash"></i></button>
            `;
            container.appendChild(row);
        }

        function removeSpecRow(btn) {
            btn.parentElement.remove();
        }

        // Modal triggers
        function openModal(id) {
            document.getElementById(id).classList.add('active');
        }

        function closeModal(id) {
            document.getElementById(id).classList.remove('active');
        }

        function openAddProductModal() {
            openModal('addProductModal');
        }

        function openEditProductModal(p) {
            document.getElementById('editProductForm').action = '/admin/products/edit/' + p.id;
            document.getElementById('edit_id').value = p.id;
            document.getElementById('edit_name').value = p.name;
            document.getElementById('edit_type').value = p.type;
            document.getElementById('edit_price_inr').value = p.price_inr;
            document.getElementById('edit_price_usd').value = p.price_usd;
            document.getElementById('edit_tag').value = p.tag || '';
            document.getElementById('edit_stock').value = p.stock_quantity || 0;
            document.getElementById('edit_desc').value = p.description;

            const catSelect = document.getElementById('edit_cat');
            catSelect.value = p.category;
            updateSubcategories(catSelect, 'edit_subcat', p.subcategory);

            const specsFields = document.getElementById('edit_specs_fields');
            specsFields.innerHTML = '';
            
            if (p.specs) {
                for (const [key, val] of Object.entries(p.specs)) {
                    addSpecRow('edit_specs_fields', key, val);
                }
            } else {
                addSpecRow('edit_specs_fields');
            }

            openModal('editProductModal');
        }

        // Action Dropdowns
        function toggleDropdownMenu(evt, anchor) {
            evt.preventDefault();
            evt.stopPropagation();
            // Close all other active dropdowns
            document.querySelectorAll('.dropdown-menu-list').forEach(menu => {
                if (menu !== anchor.nextElementSibling) menu.classList.remove('active');
            });
            anchor.nextElementSibling.classList.toggle('active');
        }

        window.addEventListener('click', () => {
            document.querySelectorAll('.dropdown-menu-list').forEach(menu => menu.classList.remove('active'));
        });

        // Search Filters Product Cards
        function filterCardsGrid() {
            const query = document.getElementById('dashboardSearch').value.toLowerCase().trim();
            const cards = document.querySelectorAll('.masterpiece-card');
            
            cards.forEach(card => {
                const name = card.getAttribute('data-name');
                const type = card.getAttribute('data-type');
                if (name.includes(query) || type.includes(query)) {
                    card.style.display = 'flex';
                } else {
                    card.style.display = 'none';
                }
            });
        }

        // Select All checkboxes
        function toggleSelectAllProducts(headerCheckbox) {
            const checkboxes = document.querySelectorAll('.item-checkbox');
            checkboxes.forEach(box => box.checked = headerCheckbox.checked);
        }

        // Order Details view
        function viewOrderDetails(orderId) {
            document.getElementById('orderItemsLoading').style.display = 'block';
            document.getElementById('orderItemsWrapper').style.display = 'none';
            openModal('orderDetailsModal');

            fetch('/api/orders/' + orderId)
                .then(res => res.json())
                .then(items => {
                    document.getElementById('orderItemsLoading').style.display = 'none';
                    document.getElementById('orderItemsWrapper').style.display = 'block';

                    const listContainer = document.getElementById('orderModalItemsList');
                    listContainer.innerHTML = '';

                    let totalINR = 0;
                    
                    items.forEach(item => {
                        totalINR += (item.price_inr * item.quantity);
                        const itemHtml = `
                            <div class="order-modal-item">
                                <img src="/${item.image_url}" alt="${item.name}" class="card-media" style="width:50px;height:50px;">
                                <div class="card-info" style="flex:1;">
                                    <h4 class="card-name" style="font-size:0.8rem;">${item.name}</h4>
                                    <p class="card-meta" style="font-size:0.7rem;">${item.type} | Qty: ${item.quantity}</p>
                                </div>
                                <div style="font-weight:600;font-size:0.8rem;">₹${(item.price_inr * item.quantity).toLocaleString('en-IN')}</div>
                            </div>
                        `;
                        listContainer.insertAdjacentHTML('beforeend', itemHtml);
                    });

                    const metaContainer = document.getElementById('orderModalDetailsMeta');
                    metaContainer.innerHTML = `
                        <div class="order-details-meta">
                            <div>
                                <span class="meta-label">DISPATCH VALUE</span>
                                <span style="font-size: 1.05rem; font-weight:700; color: var(--color-crimson);">₹${totalINR.toLocaleString('en-IN')}</span>
                            </div>
                            <div>
                                <span class="meta-label">INSURANCE CODE</span>
                                <span style="font-family: monospace; font-size:0.75rem;">YDH-2026-REG-${orderId}</span>
                            </div>
                        </div>
                    `;
                })
                .catch(err => {
                    console.error(err);
                    alert("Failure decrypting order items details.");
                    closeModal('orderDetailsModal');
                });
        }

        function openStatusUpdateModal(orderId, currentStatus) {
            document.getElementById('orderStatusForm').action = '/admin/orders/status/' + orderId;
            document.getElementById('order_status_select').value = currentStatus;
            openModal('orderStatusModal');
        }

        function openBookingStatusModal(bookingId, currentStatus) {
            document.getElementById('bookingStatusForm').action = '/admin/bookings/status/' + bookingId;
            document.getElementById('booking_status_select').value = currentStatus;
            openModal('bookingStatusModal');
        }

        // =============================================================
        // 7. PAYMENT SIMULATOR CONTROLS (matching mockup hooks)
        // =============================================================
        function runSimulatedTransaction() {
            const forceOutcome = document.getElementById('simForceOutcome').value;
            const submitBtn = document.querySelector('.floating-payment-simulator .sim-btn');
            const originalText = submitBtn.innerText;
            
            submitBtn.disabled = true;
            submitBtn.innerText = "Processing Mock...";

            // Create a valid mock checkout payload
            const mockPayload = {
                name: "Nanhan Name",
                email: "sijokurishingal91@gmail.com",
                phone: "+91 99999 77777",
                address: "Atelier Curators Boulevard, Viceroy Wing, Udaipur",
                cart: [{ id: "s1", qty: 1 }], 
                totalINR: 245000,
                totalUSD: 2950,
                paymentForceOutcome: forceOutcome
            };

            fetch('/api/checkout', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(mockPayload)
            })
            .then(res => {
                submitBtn.disabled = false;
                submitBtn.innerText = originalText;
                
                if (res.status === 200) {
                    alert("🎉 Simulated Payment SUCCESS!\nDatabase order logged, stock decremented, and PDF invoice generated.");
                    window.location.reload(); // Reload to refresh stocks grid list
                } else {
                    res.json().then(data => {
                        alert(`❌ Simulated Payment DECLINED:\n${data.error}`);
                    });
                }
            })
            .catch(err => {
                submitBtn.disabled = false;
                submitBtn.innerText = originalText;
                console.error(err);
                alert("Network error executing simulated transaction.");
            });
        }

        function downloadLastInvoice(evt) {
            evt.preventDefault();
            <% if (orders && orders.length > 0) { %>
                window.open('/admin/orders/invoice/<%= orders[0].id %>', '_blank');
            <% } else { %>
                alert("Please run a successful transaction first to generate an invoice.");
            <% } %>
        }

        function openLastEmail(evt) {
            evt.preventDefault();
            <% if (orders && orders.length > 0) { %>
                window.open('/assets/emails/email-<%= orders[0].id %>.html', '_blank');
            <% } else { %>
                alert("Please run a successful transaction first to generate an email log.");
            <% } %>
        }

        // Simulate Marketing recovery email
        function simulateDiscountRecovery(cartId, btn) {
            const originalText = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Transmitting...';

            fetch('/api/admin/abandoned-cart/recover/' + cartId, {
                method: 'POST'
            })
            .then(res => res.json())
            .then(data => {
                btn.disabled = false;
                btn.innerHTML = originalText;
                if (data.success) {
                    alert("🎉 Scarcity Recovery Email Simulated Successfully!\n10% off coupon code YADHEE10 sent to the patron.\nPreview local log at: " + data.localPath);
                    window.location.reload();
                } else {
                    alert("❌ Failed to simulate email recovery: " + data.error);
                }
            })
            .catch(err => {
                btn.disabled = false;
                btn.innerHTML = originalText;
                console.error(err);
                alert("Network error simulating recovery email.");
            });
        }
    </script>
</body>
</html>
